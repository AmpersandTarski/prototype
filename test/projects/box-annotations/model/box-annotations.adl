CONTEXT BoxAnnotations IN ENGLISH
PURPOSE CONTEXT BoxAnnotations
{+ Test project exercising the BOX-template annotations restored to the
   prototype framework: noHeader, hideOnNoRecords, hideSubOnNoRecords,
   hideLabels, title and showNavMenu (TABLE/FORM/TABS) plus table/form (RAW). +}

REPRESENT Name TYPE ALPHANUMERIC
REPRESENT Note TYPE BIGALPHANUMERIC

RELATION catName    [Category*Name] [UNI]
RELATION catNote    [Category*Note] [UNI]
RELATION catProduct [Category*Product]
RELATION prodCode   [Product*Name] [UNI]
RELATION prodName   [Product*Name] [UNI]

-- Root overview: lists every category in a TABLE with a title and a per-row
-- navigation menu (title + showNavMenu).
INTERFACE Categories : "_SESSION";V[SESSION*Category] cRud BOX<TABLE title="All categories" showNavMenu>
   [ "Name"     : catName cRUd
   , "Products" : catProduct cRud
   ]

-- Category detail in TABS: a title, panels hidden when their field is empty
-- (hideSubOnNoRecords). The Products panel is a TABLE without a header row
-- (noHeader). The Note table hides entirely when empty (hideOnNoRecords).
INTERFACE Category : I[Category] cRud BOX<TABS title="Category detail" hideSubOnNoRecords>
   [ "Name"     : catName cRUd
   , "Note"     : catNote cRUd
   , "Products" : catProduct cRud BOX<TABLE noHeader hideOnNoRecords>
        [ "Code" : prodCode cRUd
        , "Name" : prodName cRUd
        ]
   ]

-- FORM variant: a title, field rows hidden when empty (hideSubOnNoRecords),
-- and the whole form hidden when the category itself is gone (hideOnNoRecords).
INTERFACE CategoryForm : I[Category] cRud BOX<FORM title="Category (form)" hideSubOnNoRecords hideOnNoRecords>
   [ "Name" : catName cRUd
   , "Note" : catNote cRUd
   ]

-- FORM with labels hidden (hideLabels).
INTERFACE CategoryCompact : I[Category] cRud BOX<FORM hideLabels>
   [ "Name" : catName cRUd
   , "Note" : catNote cRUd
   ]

-- RAW with a tabular layout (table).
INTERFACE CategoryRawTable : I[Category] cRud BOX<RAW table>
   [ "Name" : catName cRUd
   , "Note" : catNote cRUd
   ]

-- RAW wrapped in a non-submitting form element (form).
INTERFACE CategoryRawForm : I[Category] cRud BOX<RAW form>
   [ "Name" : catName cRUd
   , "Note" : catNote cRUd
   ]

-- Regression: `sortable` column headers. The header cells live in a template
-- that is declared outside the p-table, so PrimeNG's own sort directives
-- cannot be injected there; every render of a sortable table crashed with
-- "can't access property tableService, this.dt is undefined". The framework
-- now uses its own appSortableColumn/app-sort-icon (see Box-TABLE.html and
-- SortableColumnDirective). Expected: no console errors, clicking "Name" or
-- "Note" sorts the rows and updates the sort icon; "Products" (not UNI)
-- renders as a plain, unsortable header.
INTERFACE CategoriesSortable : "_SESSION";V[SESSION*Category] cRud BOX<TABLE sortable title="Categories (sortable)">
   [ "Name"     : catName cRUd
   , "Note"     : catNote cRUd
   , "Products" : catProduct cRud
   ]

-- Population so the sortable table has rows to reorder.
POPULATION catName CONTAINS [ ("cat1", "Beta"), ("cat2", "Alpha"), ("cat3", "Gamma") ]
POPULATION catNote CONTAINS [ ("cat1", "second"), ("cat2", "first"), ("cat3", "third") ]
POPULATION prodCode CONTAINS [ ("prod1", "P-001") ]
POPULATION prodName CONTAINS [ ("prod1", "Widget") ]
POPULATION catProduct CONTAINS [ ("cat1", "prod1") ]

ENDCONTEXT
